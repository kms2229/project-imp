#!/bin/bash -l

# ============================================================
# MIMIC STEP 2: Extract structured + language embeddings
# Submit: qsub qevc/scripts/extract_mimic.qsub
#
# Reads CHARTEVENTS (~33 GB), LABEVENTS (~2 GB), NOTEEVENTS
# and produces: es_{split}.npy, el_{split}.npy, meta_{split}.npz
# ============================================================

#$ -P llm-plastsurg
#$ -N mimic_extract
#$ -l gpus=1
#$ -l gpu_type=L40S
#$ -l h_rt=12:00:00
#$ -l mem_total=64G
#$ -pe omp 8
#$ -j y
#$ -o /projectnb/llm-plastsurg/kms_new/logs/mimic_extract_$JOB_ID.log

echo "============================================================"
echo "Job started: $(date)"
echo "Node: $(hostname) | Job ID: $JOB_ID"
echo "GPU: $(nvidia-smi --query-gpu=name,memory.total --format=csv,noheader 2>/dev/null)"
echo "============================================================"

module load python3/3.10.12
module load cuda/11.8

export PROJECT_DIR=/projectnb/llm-plastsurg/kms_new
export PYTHONUSERBASE=$PROJECT_DIR/.qevc_env
export PATH=$PYTHONUSERBASE/bin:$PATH
export PYTHONPATH=$PROJECT_DIR/.qevc_env/lib/python3.10/site-packages:$PROJECT_DIR/project-imp:$PYTHONPATH
export HF_HOME=$PROJECT_DIR/.cache/huggingface
export TRANSFORMERS_CACHE=$PROJECT_DIR/.cache/huggingface/hub

cd $PROJECT_DIR/project-imp

# Run MIMIC embedding extraction
python3 -m qevc.scripts.extract_embeddings --dataset mimic --device cuda --batch-size 32

echo ""
echo "Job finished: $(date)"
