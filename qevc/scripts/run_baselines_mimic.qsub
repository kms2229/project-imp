#!/bin/bash -l

# ============================================================
# MIMIC STEP 5: Run classical baselines on MIMIC-III
# Submit: qsub qevc/scripts/run_baselines_mimic.qsub
# ============================================================

#$ -P llm-plastsurg
#$ -N mimic_baselines
#$ -l gpus=1
#$ -l h_rt=04:00:00
#$ -l mem_total=32G
#$ -pe omp 4
#$ -j y
#$ -o /projectnb/llm-plastsurg/kms_new/logs/mimic_baselines_$JOB_ID.log

echo "Job started: $(date) | Node: $(hostname)"

module load python3/3.10.12
module load cuda/11.8

export PROJECT_DIR=/projectnb/llm-plastsurg/kms_new
export PYTHONUSERBASE=$PROJECT_DIR/.qevc_env
export PATH=$PYTHONUSERBASE/bin:$PATH
export PYTHONPATH=$PROJECT_DIR/.qevc_env/lib/python3.10/site-packages:$PROJECT_DIR/project-imp:$PYTHONPATH

cd $PROJECT_DIR/project-imp

python3 -m qevc.scripts.run_baselines --dataset mimic --baselines all

echo "Job finished: $(date)"
