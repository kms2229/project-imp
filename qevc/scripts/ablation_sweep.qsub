#!/bin/bash -l

# ============================================================
# STEP 5: Ablation sweep (λ values + circuit depth)
# Submit: qsub -t 1-9 qevc/scripts/ablation_sweep.qsub
#
# Task array: 9 jobs running in parallel
#   1-5: λ sweep (0.1, 0.25, 0.5, 0.75, 1.0)
#   6-9: depth sweep (L=2, 4, 6, 8)
# ============================================================

#$ -P llm-plastsurg
#$ -N qevc_ablation
#$ -l gpus=1
#$ -l h_rt=24:00:00
#$ -l mem_total=32G
#$ -pe omp 4
#$ -j y
#$ -o /projectnb/llm-plastsurg/kms_new/logs/ablation_$JOB_ID_$TASK_ID.log

echo "Job started: $(date) | Task: $SGE_TASK_ID"

module load python3/3.10.12
module load cuda/11.8

export PROJECT_DIR=/projectnb/llm-plastsurg/kms_new
export PYTHONUSERBASE=$PROJECT_DIR/.qevc_env
export PATH=$PYTHONUSERBASE/bin:$PATH
export PYTHONPATH=$PROJECT_DIR/.qevc_env/lib/python3.10/site-packages:$PROJECT_DIR/project-imp:$PYTHONPATH
export HF_HOME=$PROJECT_DIR/.cache/huggingface

cd $PROJECT_DIR/project-imp

# Lambda sweep
LAMBDAS=(0.1 0.25 0.5 0.75 1.0)
# Depth sweep
DEPTHS=(2 4 6 8)

TASK_ID=${SGE_TASK_ID:-1}

if [ $TASK_ID -le 5 ]; then
    # Lambda ablation (index 0-4)
    L_IDX=$((TASK_ID - 1))
    LAM=${LAMBDAS[$L_IDX]}
    echo "Lambda ablation: λ=$LAM"
    python3 -m qevc.scripts.train_qevc --dataset vqacp --device cuda --lam $LAM
elif [ $TASK_ID -le 9 ]; then
    # Depth ablation (index 0-3)
    D_IDX=$((TASK_ID - 6))
    DEPTH=${DEPTHS[$D_IDX]}
    echo "Depth ablation: L=$DEPTH"
    python3 -m qevc.scripts.train_qevc --dataset vqacp --device cuda --n-layers $DEPTH
fi

echo "Job finished: $(date)"
