#!/bin/bash -l

# ============================================================
# STEP 3: Train QEVC on real VQA-CP features
# Submit: qsub qevc/scripts/train_vqa.qsub
#
# For sanity check first:
#   qsub -v N_SAMPLES=500,EPOCHS=5 qevc/scripts/train_vqa.qsub
# ============================================================

#$ -P llm-plastsurg
#$ -N qevc_train
#$ -l gpus=1
#$ -l h_rt=24:00:00
#$ -l mem_total=32G
#$ -pe omp 4
#$ -j y
#$ -o /projectnb/llm-plastsurg/kms_new/logs/train_vqa_$JOB_ID.log

echo "Job started: $(date)"
echo "Node: $(hostname)"
echo "Job ID: $JOB_ID"

module load python3/3.10.12
module load cuda/11.8

export PROJECT_DIR=/projectnb/llm-plastsurg/kms_new
export PYTHONUSERBASE=$PROJECT_DIR/.qevc_env
export PATH=$PYTHONUSERBASE/bin:$PATH
export PYTHONPATH=$PROJECT_DIR/.qevc_env/lib/python3.10/site-packages:$PROJECT_DIR/project-imp:$PYTHONPATH
export HF_HOME=$PROJECT_DIR/.cache/huggingface
export TRANSFORMERS_CACHE=$PROJECT_DIR/.cache/huggingface/hub

cd $PROJECT_DIR/project-imp

echo "GPU: $(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null || echo 'none')"

# Build command with optional overrides
CMD="python3 -m qevc.scripts.train_qevc --dataset vqacp --device cuda"

if [ -n "$N_SAMPLES" ]; then CMD="$CMD --n-samples $N_SAMPLES"; fi
if [ -n "$EPOCHS" ]; then CMD="$CMD --epochs $EPOCHS"; fi
if [ -n "$LAMBDA" ]; then CMD="$CMD --lam $LAMBDA"; fi
if [ -n "$N_LAYERS" ]; then CMD="$CMD --n-layers $N_LAYERS"; fi

echo "Running: $CMD"
eval "$CMD"

echo "Job finished: $(date)"
