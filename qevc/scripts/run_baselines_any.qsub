#!/bin/bash -l

# ============================================================
# Run all classical baselines (SVM, MLP, AdvDeb, DBA)
# Submit: qsub qevc/scripts/run_baselines_any.qsub
#
# Baselines are lightweight — any GPU type works fine.
# ============================================================

#$ -P llm-plastsurg
#$ -N qevc_baselines
#$ -l gpus=1
#$ -l h_rt=04:00:00
#$ -l mem_total=32G
#$ -pe omp 4
#$ -j y
#$ -o /projectnb/llm-plastsurg/kms_new/logs/baselines_$JOB_ID.log

echo "Job started: $(date) | Node: $(hostname)"
echo "GPU: $(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null)"

module load python3/3.10.12
module load cuda/11.8

export PROJECT_DIR=/projectnb/llm-plastsurg/kms_new
export PYTHONUSERBASE=$PROJECT_DIR/.qevc_env
export PATH=$PYTHONUSERBASE/bin:$PATH
export PYTHONPATH=$PROJECT_DIR/.qevc_env/lib/python3.10/site-packages:$PROJECT_DIR/project-imp:$PYTHONPATH

cd $PROJECT_DIR/project-imp

python3 -m qevc.scripts.run_baselines --dataset vqacp --baselines all

echo "Job finished: $(date)"
