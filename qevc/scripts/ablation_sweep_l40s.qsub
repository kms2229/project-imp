#!/bin/bash -l

# ============================================================
# Ablation sweep: λ values, circuit depth, and entanglement (L40S GPUs)
# Submit: qsub -t 1-11 qevc/scripts/ablation_sweep_l40s.qsub
#
# Task array: 11 parallel 1-GPU jobs
#   1-5: λ sweep (0.1, 0.25, 0.5, 0.75, 1.0)
#   6-9: depth sweep (L=2, 4, 6, 8)
#  10-11: entanglement ablation (0=no CNOTs, 1=with CNOTs)
#
# Uses L40S for consistent timing across ablation runs.
# ============================================================

#$ -P llm-plastsurg
#$ -N qevc_ablation
#$ -l gpus=1
#$ -l gpu_type=L40S
#$ -l h_rt=24:00:00
#$ -l mem_total=32G
#$ -pe omp 4
#$ -j y
#$ -o /projectnb/llm-plastsurg/kms_new/logs/ablation_$JOB_ID_$TASK_ID.log

echo "============================================================"
echo "Job started: $(date)"
echo "Node: $(hostname) | Job ID: $JOB_ID | Task: $SGE_TASK_ID"
echo "GPU: $(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null)"
echo "============================================================"

module load python3/3.10.12
module load cuda/11.8

export PROJECT_DIR=/projectnb/llm-plastsurg/kms_new
export PYTHONUSERBASE=$PROJECT_DIR/.qevc_env
export PATH=$PYTHONUSERBASE/bin:$PATH
export PYTHONPATH=$PROJECT_DIR/.qevc_env/lib/python3.10/site-packages:$PROJECT_DIR/project-imp:$PYTHONPATH
export HF_HOME=$PROJECT_DIR/.cache/huggingface

cd $PROJECT_DIR/project-imp

# Lambda sweep values
LAMBDAS=(0.1 0.25 0.5 0.75 1.0)
# Depth sweep values
DEPTHS=(2 4 6 8)
# Entanglement sweep values (0=False, 1=True)
ENTANGLING=(0 1)

TASK_ID=${SGE_TASK_ID:-1}

if [ $TASK_ID -le 5 ]; then
    # Lambda ablation (tasks 1-5)
    L_IDX=$((TASK_ID - 1))
    LAM=${LAMBDAS[$L_IDX]}
    echo "Lambda ablation: λ=$LAM"
    python3 -m qevc.scripts.train_qevc --dataset vqacp --device cuda --lam $LAM --n-samples 40000 --epochs 5
elif [ $TASK_ID -le 9 ]; then
    # Depth ablation (tasks 6-9)
    D_IDX=$((TASK_ID - 6))
    DEPTH=${DEPTHS[$D_IDX]}
    echo "Depth ablation: L=$DEPTH"
    python3 -m qevc.scripts.train_qevc --dataset vqacp --device cuda --n-layers $DEPTH --n-samples 40000 --epochs 5
elif [ $TASK_ID -le 11 ]; then
    # Entanglement ablation (tasks 10-11)
    E_IDX=$((TASK_ID - 10))
    ENT=${ENTANGLING[$E_IDX]}
    echo "Entanglement ablation: CNOTs=$ENT"
    if [ $ENT -eq 0 ]; then
        python3 -m qevc.scripts.train_qevc --dataset vqacp --device cuda --no-entangling --n-samples 40000 --epochs 5
    else
        python3 -m qevc.scripts.train_qevc --dataset vqacp --device cuda --n-samples 40000 --epochs 5
    fi
fi

echo "Job finished: $(date)"
